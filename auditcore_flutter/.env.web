# ─── AuditCore Flutter — Variables de entorno para WEB con Docker ────────────
#
# Flutter → localhost:3000 (Nginx) → backend:8000 (interno Docker)
# Nginx hace el proxy internamente, Flutter NUNCA llama directo al 8000.
#
# Para restaurar después de correr Android:
#   Windows: copy .env.web .env
#   macOS/Linux: cp .env.web .env
#
# ─────────────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3000
WS_BASE_URL=ws://localhost:3000

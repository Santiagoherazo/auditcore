# ═══════════════════════════════════════════════════════════════════════════════
#  AuditCore Backend — Variables de Entorno
#  Copia este archivo a .env y completa los valores reales.
#  NUNCA commitear .env con valores reales al repositorio.
# ═══════════════════════════════════════════════════════════════════════════════

# Django
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-REEMPLAZAR-CON-CLAVE-SEGURA-DE-50-CHARS-MINIMO
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend,frontend
DJANGO_SETTINGS_MODULE=config.settings.development

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Base de datos PostgreSQL
DATABASE_URL=postgres://auditcore_user:TU_PASSWORD_AQUI@postgres:5432/auditcore

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://auditcore:TU_PASSWORD_AQUI@rabbitmq:5672/auditcore?heartbeat=120

# Ollama — LLM local para el chatbot
# Opción A: servidor externo
OLLAMA_BASE_URL=https://tu-servidor-ollama.com:11435
# Opción B: contenedor Docker local
# OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_SSL_VERIFY=False
OLLAMA_MODEL=llama3.1:8b

# Email SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password-gmail
DEFAULT_FROM_EMAIL=AuditCore <noreply@tudominio.com>

# Frontend
FRONTEND_URL=http://localhost:3000

# Almacenamiento
MEDIA_ROOT=media
